# ==============================
# AUTH
# ==============================
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your_secret_here_run_openssl_rand_base64_32

# Google OAuth (Google Console → Credentials)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# ==============================
# AI KEYS
# ==============================
# Google AI (Imagen 3 + Gemini)
GOOGLE_AI_API_KEY=your_google_ai_api_key

# OpenAI (GPT-4o для генерации промптов)
OPENAI_API_KEY=your_openai_api_key

# ==============================
# DATABASE
# ==============================
# Railway PostgreSQL (добавится автоматически на Railway)
DATABASE_URL=postgresql://user:password@localhost:5432/creative_studio

# ==============================
# STORAGE (для загрузки референсов)
# ==============================
# Можно использовать Cloudinary или просто локально для начала
CLOUDINARY_URL=your_cloudinary_url
